# =====================================================
# 古代铸钟工艺仿真与钟声传播模拟系统 - 环境变量配置
# 复制为 .env 后修改
# =====================================================

# ======== HTTP 服务 ========
SERVER_PORT=8080

# ======== ClickHouse 数据库 ========
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=bell_casting

# ======== MQTT 消息队列 ========
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_CLIENT_ID=bell_casting_backend
MQTT_TOPIC=bell_casting/alerts
# 可选：MQTT认证
# MQTT_USERNAME=admin
# MQTT_PASSWORD=password

# ======== 日志级别 ========
RUST_LOG=info,bell_casting_backend=debug
